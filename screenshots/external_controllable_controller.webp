                      <div class="input-wrapper _input-wrapper">
                        <div class="c7684e6e4 cdd6448e7 password c1c548c82 ulp-field" data-action-text="" data-alternate-action-text="">
                          <label id="password-label" class="c6875e265 cc134ffa5 cb8a397fb" for="password">
                            Password
                          
                            <span class="required" aria-hidden="true">*</span>
                          </label>
                        
                          <input class="input cb91b73c7 c77d8fc90" name="password" id="password" type="password" aria-labelledby="password-label" aria-required="true" required autoComplete="current-password" autoCapitalize="none" spellCheck="false">
                        
                          
                            <button type="button" role="switch" aria-checked="false" aria-label="Show password" class="c97a437dc ulp-button-icon js-required cfc1b9320 _button-icon" data-action="toggle">
                              <span aria-hidden="true" class="password-icon-tooltip show-password-tooltip">Show password</span>
                            
                              <span aria-hidden="true" class="password-icon-tooltip hide-password-tooltip hide">Hide password</span>
                            
                              <span class="c05cca2b4 password js-required" aria-hidden="true"></span>
                            </button>
                          
                        </div>
                      
                        
                          <div id="error-cs-password-required" class="ulp-error-info aria-error-check" data-ulp-validation-function="ulpRequiredFunction" data-ulp-validation-event-listeners="blur,change,input,focus" data-ulp-validation-target="password" aria-live="polite" aria-atomic="true">
