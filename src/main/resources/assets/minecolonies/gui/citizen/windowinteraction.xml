<window size="350 170" lightbox="true">
    <switch id="head" size="100% 100%" pos="0 0">
        <view id="interactionView">
            <gradient id="gradient" size="300 170" pos="20 0"/>
            <text id="chat" size="250 100" color="white" pos="30 15"/>
            <box id="responseOptions" size="270 70" pos="30 100" linewidth="0"/>

            <itemicon id="requestItem" size="32 32" pos="30 60"/>
        </view>
    </switch>
    <button id="cancel" pos="303 1" size="14 15"
                 source="minecolonies:textures/gui/button_x.png" color="black" tooltip="$(com.minecolonies.core.exit_interactions)"/>
    <image id="magicworldThemeIcon" pos="4 2" size="12 12" source="magicworld:textures/gui/embeddium_magicworld_icon.png"/>
    <text id="magicworldThemeBrand" pos="18 3" size="132 10" label="MAGIC WORLD COLONIES" color="gold" textscale="0.65"/></window>
